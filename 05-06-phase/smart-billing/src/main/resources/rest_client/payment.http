### Global Variables
@baseUrl = http://localhost:8181/api/v1/payment
@contentType = application/json

### Get all payments
GET {{baseUrl}}
Content-Type: {{contentType}}

### Get payment by ID
GET {{baseUrl}}/1
Content-Type: {{contentType}}

### Create payment
POST {{baseUrl}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "invoiceId": 1,
  "paymentDate": "2026-05-10T14:30:00",
  "amountPaid": 2700.00,
  "paymentMethod": "CREDIT_CARD",
  "referenceNumber": "REF-987654"
}

### Update payment
PUT {{baseUrl}}/1
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "invoiceId": 4,
  "paymentDate": "2026-05-11T10:00:00",
  "amountPaid": 2800.00,
  "paymentMethod": "BANK_TRANSFER",
  "referenceNumber": "REF-123456"
}

### Delete payment
DELETE {{baseUrl}}/1
Accept: {{contentType}}
